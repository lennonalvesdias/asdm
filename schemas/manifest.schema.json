{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asdm.dev/schemas/manifest.schema.json",
  "title": "ASDM Manifest",
  "description": "Schema for manifest.json generated by CI",
  "type": "object",
  "required": ["version", "built_at", "commit_sha", "policy", "profiles", "assets"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "built_at": {
      "type": "string",
      "format": "date-time"
    },
    "commit_sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{7,40}$"
    },
    "policy": {
      "type": "object",
      "required": ["allowed_profiles", "allowed_providers", "min_cli_version"],
      "additionalProperties": false,
      "properties": {
        "locked_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "telemetry": { "type": "boolean" },
        "auto_verify": { "type": "boolean" },
        "install_hooks": { "type": "boolean" },
        "allowed_profiles": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "allowed_providers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["opencode", "claude-code", "copilot"]
          },
          "minItems": 1
        },
        "min_cli_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "extends": {
            "type": "array",
            "items": { "type": "string" }
          },
          "agents": {
            "type": "array",
            "items": { "type": "string" }
          },
          "skills": {
            "type": "array",
            "items": { "type": "string" }
          },
          "commands": {
            "type": "array",
            "items": { "type": "string" }
          },
          "providers": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["sha256", "size", "version"],
        "additionalProperties": false,
        "properties": {
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "size": {
            "type": "integer",
            "minimum": 0
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          }
        }
      }
    }
  }
}
