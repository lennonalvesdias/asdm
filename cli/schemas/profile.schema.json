{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asdm.dev/schemas/profile.schema.json",
  "title": "ASDM Profile",
  "description": "Schema for ASDM profile.yaml",
  "type": "object",
  "required": ["name"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "description": {
      "type": "string"
    },
    "extends": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Parent profiles to inherit from"
    },
    "agents": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "skills": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "commands": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "providers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["opencode", "claude-code", "copilot", "agents-dir"]
      },
      "uniqueItems": true
    },
    "provider_config": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "opencode": {
          "type": "object",
          "additionalProperties": true,
          "description": "Passthrough config for opencode.jsonc — see https://opencode.ai/docs/config/",
          "properties": {
            "model": { "type": "string", "description": "Default model (provider/model-id)" },
            "small_model": { "type": "string", "description": "Lightweight model for title generation" },
            "default_agent": { "type": "string", "description": "Default primary agent name" },
            "agent": { "type": "object", "additionalProperties": true, "description": "Per-agent runtime config (model, temperature, permissions)" },
            "permission": { "description": "Top-level tool permission rules" },
            "mcp": { "type": "object", "additionalProperties": true, "description": "MCP server definitions" },
            "plugin": { "type": "array", "items": { "type": "string" }, "description": "npm plugin package names" },
            "instructions": { "type": "array", "items": { "type": "string" }, "description": "Additional instruction files, globs, or URLs" },
            "tools": { "type": "object", "additionalProperties": true, "description": "Tool enable/disable map" },
            "command": { "type": "object", "additionalProperties": true, "description": "Custom slash command definitions" },
            "formatter": { "description": "Code formatter config (object or false to disable all)" },
            "lsp": { "description": "LSP server config (object or false to disable all)" },
            "provider": { "type": "object", "additionalProperties": true, "description": "Provider/model configuration" },
            "share": { "type": "string", "enum": ["manual", "auto", "disabled"] },
            "autoupdate": { "description": "true | false | \"notify\"" },
            "compaction": { "type": "object", "additionalProperties": true },
            "watcher": { "type": "object", "additionalProperties": true },
            "experimental": { "type": "object", "additionalProperties": true }
          }
        },
        "claude-code": {
          "type": "object",
          "additionalProperties": true
        },
        "copilot": {
          "type": "object",
          "additionalProperties": true
        },
        "agents-dir": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
